# ============================================================
# Midnight Moodvie — Directus self-hosted (Local Docker / Mac)
# 複製為 .env 後填入實際值（.env 已被 .gitignore 排除，請勿 commit）
# ============================================================

# 對外 URL（含 protocol）
# 本機開發：http://localhost:8055
# 之後上 VPS / 反向代理時改為 https://directus.your-domain.com
PUBLIC_URL=http://localhost:8055

# Directus 內部加密 secret
# Mac 產生方式：openssl rand -hex 32
DIRECTUS_KEY=REPLACE_WITH_RANDOM_HEX_32
DIRECTUS_SECRET=REPLACE_WITH_RANDOM_HEX_32

# 第一次啟動會用這組建立 admin 帳號；之後改密碼請到 Data Studio
ADMIN_EMAIL=admin@midnight-moodvie.local
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Postgres
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# CORS：允許前端的來源
# 本機開發：http://localhost:5173（Vite 預設）
# 多個來源用逗號分隔，或填 true 允許全部（不建議 prod）
CORS_ORIGIN=http://localhost:5173

# ============================================================
# 給 frontend 的環境變數（複製到專案的 .env.local）
# ============================================================
# VITE_DIRECTUS_URL=http://localhost:8055
